# Market Forecasting Configuration
# Copy this to .env and customize as needed

# Forecasting Parameters
#MARKET_WINDOW_SIZE=100
MARKET_FORECAST_HORIZON=18
MARKET_RESAMPLE=5min
MARKET_N_NEIGHBORS=7
MARKET_DISTANCE_METRIC=ddtw
MARKET_NORM_METHOD=log
MARKET_FORECAST_IMPL=avg
MARKET_FEATURE_COL=close
MARKET_TIMEZONE=America/New_York

# DTW Distance Parameters (used when MARKET_DISTANCE_METRIC=dtw or ddtw)
# Sakoe-Chiba band: 0-1 constrains warping (0.2 = 20% window)
MARKET_DTW_SC_BAND=0.2
 # Itakura parallelogram: >1.0 alternative to window
# MARKET_DTW_ITAKURA_MAX_SLOPE=2.0

# Data Path (relative to project root or absolute)
MARKET_DATA_PATH=data/test/NQ_2024-09-06_2025-09-13.parquet

# Visualization
MARKET_NEIGHBOR_SUBPLOTS=true
MARKET_PLOT_WIDTH=1200
MARKET_PLOT_HEIGHT=600

# Optional: limit windows for faster testing
# MARKET_MAX_WINDOWS=30

# Optional: override project root for path resolution
# MARKET_PROJECT_ROOT=/path/to/project
